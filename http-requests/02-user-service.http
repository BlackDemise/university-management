###
# Update User (use existing ID)
POST {{baseUrl}}/api/v1/user/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "id": {{studentId}},
  "fullName": "John Doe Updated",
  "email": "john.doe.updated@university.edu",
  "role": "STUDENT",
  "phone": "+1234567890",
  "identityNumber": "123456789",
  "permanentAddress": "123 Main St, City, Country",
  "currentAddress": "456 University Ave, Campus City",
  "studentRequest": {
    "id": "62",
    "majorId": {{majorId}},
    "studentStatus": "ACTIVE",
    "studentCode": "ST061-UPDATED-2",
    "admissionYear": 2023
  }
}

###
# Delete User by ID
DELETE {{baseUrl}}/api/v1/user/delete/{{studentId}}
Authorization: {{authHeader}}

###
# Validate Teacher (Service-to-Service)
GET {{baseUrl}}/api/v1/user/teachers/{{teacherId}}/validate
Authorization: {{authHeader}}

###
# Validate Student (Service-to-Service)
GET {{baseUrl}}/api/v1/user/students/{{studentId}}/validate
Authorization: {{authHeader}} 