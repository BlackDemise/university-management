### Facility Service API Tests
### Base URL: {{baseUrl}}/api/v1/classroom

###
# Get All Classrooms
GET {{baseUrl}}/api/v1/classroom/all
Authorization: {{authHeader}}

###
# Get Classroom by ID
GET {{baseUrl}}/api/v1/classroom/details/{{classroomId}}
Authorization: {{authHeader}}

###
# Create Lecture Hall
POST {{baseUrl}}/api/v1/classroom/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "roomNumber": "A101",
  "building": "Engineering Building",
  "capacity": 50,
  "equipment": "Projector, Whiteboard, Microphone",
  "classroomType": "LECTURE_HALL"
}

###
# Create Computer Lab
POST {{baseUrl}}/api/v1/classroom/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "roomNumber": "B201",
  "building": "Computer Science Building",
  "capacity": 30,
  "equipment": "30 Desktop Computers, Projector, Air Conditioning",
  "classroomType": "LAB"
}

###
# Create Seminar Room
POST {{baseUrl}}/api/v1/classroom/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "roomNumber": "C301",
  "building": "Administrative Building",
  "capacity": 15,
  "equipment": "Conference Table, TV Screen, Video Conferencing",
  "classroomType": "SEMINAR_ROOM"
}

###
# Create Large Auditorium
POST {{baseUrl}}/api/v1/classroom/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "roomNumber": "MAIN-AUDITORIUM",
  "building": "Central Building",
  "capacity": 200,
  "equipment": "Large Screen, Audio System, Stage, Podium",
  "classroomType": "LECTURE_HALL"
}

###
# Create Chemistry Lab
POST {{baseUrl}}/api/v1/classroom/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "roomNumber": "D102",
  "building": "Science Building",
  "capacity": 25,
  "equipment": "Lab Benches, Fume Hoods, Chemical Storage, Safety Equipment",
  "classroomType": "LAB"
}

###
# Update Classroom
POST {{baseUrl}}/api/v1/classroom/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "id": {{classroomId}},
  "roomNumber": "A101-UPGRADED",
  "building": "Engineering Building",
  "capacity": 55,
  "equipment": "Smart Board, Projector, Microphone, Document Camera",
  "classroomType": "LECTURE_HALL"
}

###
# Delete Classroom
DELETE {{baseUrl}}/api/v1/classroom/delete/{{classroomId}}
Authorization: {{authHeader}}

###
# Validate Classroom (Service-to-Service)
GET {{baseUrl}}/api/v1/classroom/validate/{{classroomId}}
Authorization: {{authHeader}} 