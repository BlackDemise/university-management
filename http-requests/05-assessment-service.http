### Assessment Service API Tests
### Base URL: {{baseUrl}}/api/v1

# ========================================
# GRADE ENDPOINTS
# ========================================

###
# Get All Grades
GET {{baseUrl}}/api/v1/grade/all
Authorization: {{authHeader}}

###
# Get Grade by ID
GET {{baseUrl}}/api/v1/grade/details/{{gradeId}}
Authorization: {{authHeader}}

###
# Create Midterm Grade
POST {{baseUrl}}/api/v1/grade/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "scoreType": "MIDTERM",
  "scoreValue": 8.5,
  "courseRegistrationId": {{courseRegistrationId}}
}

###
# Create Final Grade
POST {{baseUrl}}/api/v1/grade/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "scoreType": "FINAL",
  "scoreValue": 9.0,
  "courseRegistrationId": {{courseRegistrationId}}
}

###
# Create Quiz Grade
POST {{baseUrl}}/api/v1/grade/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "scoreType": "QUIZ",
  "scoreValue": 7.5,
  "courseRegistrationId": {{courseRegistrationId}}
}

###
# Create Assignment Grade
POST {{baseUrl}}/api/v1/grade/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "scoreType": "ASSIGNMENT",
  "scoreValue": 8.0,
  "courseRegistrationId": {{courseRegistrationId}}
}

###
# Create Perfect Score Grade
POST {{baseUrl}}/api/v1/grade/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "scoreType": "FINAL",
  "scoreValue": 10.0,
  "courseRegistrationId": 2
}

###
# Update Grade
POST {{baseUrl}}/api/v1/grade/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "id": {{gradeId}},
  "scoreType": "MIDTERM",
  "scoreValue": 9.0,
  "courseRegistrationId": {{courseRegistrationId}}
}

###
# Delete Grade
DELETE {{baseUrl}}/api/v1/grade/delete/{{gradeId}}
Authorization: {{authHeader}}

# ========================================
# SESSION ENDPOINTS
# ========================================

###
# Get All Sessions
GET {{baseUrl}}/api/v1/session/all
Authorization: {{authHeader}}

###
# Get Session by ID
GET {{baseUrl}}/api/v1/session/details/{{sessionId}}
Authorization: {{authHeader}}

###
# Create Lecture Session
POST {{baseUrl}}/api/v1/session/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "sessionDate": "2023-09-15T10:00:00",
  "sessionType": "LECTURE",
  "courseOfferingId": {{courseOfferingId}}
}

###
# Create Lab Session
POST {{baseUrl}}/api/v1/session/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "sessionDate": "2023-09-17T14:00:00",
  "sessionType": "LAB",
  "courseOfferingId": {{courseOfferingId}}
}

###
# Create Tutorial Session
POST {{baseUrl}}/api/v1/session/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "sessionDate": "2023-09-20T09:00:00",
  "sessionType": "TUTORIAL",
  "courseOfferingId": {{courseOfferingId}}
}

###
# Create Exam Session
POST {{baseUrl}}/api/v1/session/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "sessionDate": "2023-10-15T13:00:00",
  "sessionType": "EXAM",
  "courseOfferingId": {{courseOfferingId}}
}

###
# Update Session
POST {{baseUrl}}/api/v1/session/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "id": {{sessionId}},
  "sessionDate": "2023-09-15T10:30:00",
  "sessionType": "LECTURE",
  "courseOfferingId": {{courseOfferingId}}
}

###
# Delete Session
DELETE {{baseUrl}}/api/v1/session/delete/{{sessionId}}
Authorization: {{authHeader}}

# ========================================
# ATTENDANCE ENDPOINTS
# ========================================

###
# Get All Attendances
GET {{baseUrl}}/api/v1/attendance/all
Authorization: {{authHeader}}

###
# Get Attendance by ID
GET {{baseUrl}}/api/v1/attendance/details/1
Authorization: {{authHeader}}

###
# Create Present Attendance
POST {{baseUrl}}/api/v1/attendance/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "attendanceStatus": "PRESENT",
  "studentId": {{studentId}},
  "sessionId": {{sessionId}}
}

###
# Create Absent Attendance
POST {{baseUrl}}/api/v1/attendance/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "attendanceStatus": "ABSENT",
  "studentId": 2,
  "sessionId": {{sessionId}}
}

###
# Create Late Attendance
POST {{baseUrl}}/api/v1/attendance/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "attendanceStatus": "LATE",
  "studentId": 3,
  "sessionId": {{sessionId}}
}

###
# Update Attendance Status
POST {{baseUrl}}/api/v1/attendance/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "id": 1,
  "attendanceStatus": "PRESENT",
  "studentId": {{studentId}},
  "sessionId": {{sessionId}}
}

###
# Delete Attendance
DELETE {{baseUrl}}/api/v1/attendance/delete/1
Authorization: {{authHeader}} 