### Enrollment Service API Tests
### Base URL: {{baseUrl}}/api/v1

# ========================================
# SEMESTER ENDPOINTS
# ========================================

###
# Get All Semesters
GET {{baseUrl}}/api/v1/semester/all
Authorization: {{authHeader}}

###
# Get Semester by ID
GET {{baseUrl}}/api/v1/semester/details/{{semesterId}}
Authorization: {{authHeader}}

###
# Create Semester
POST {{baseUrl}}/api/v1/semester/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "name": "Fall 2023",
  "startDate": "2023-09-01T00:00:00",
  "endDate": "2023-12-15T23:59:59"
}

###
# Create Spring Semester
POST {{baseUrl}}/api/v1/semester/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "name": "Spring 2024",
  "startDate": "2024-01-15T00:00:00",
  "endDate": "2024-05-30T23:59:59"
}

###
# Create Summer Semester
POST {{baseUrl}}/api/v1/semester/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "name": "Summer 2024",
  "startDate": "2024-06-01T00:00:00",
  "endDate": "2024-08-15T23:59:59"
}

###
# Update Semester
POST {{baseUrl}}/api/v1/semester/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "id": {{semesterId}},
  "name": "Fall 2023 (Updated)",
  "startDate": "2023-09-01T00:00:00",
  "endDate": "2023-12-20T23:59:59"
}

###
# Delete Semester
DELETE {{baseUrl}}/api/v1/semester/delete/{{semesterId}}
Authorization: {{authHeader}}

# ========================================
# COURSE OFFERING ENDPOINTS
# ========================================

###
# Get All Course Offerings
GET {{baseUrl}}/api/v1/course-offering/all
Authorization: {{authHeader}}

###
# Get Course Offering by ID
GET {{baseUrl}}/api/v1/course-offering/details/{{courseOfferingId}}
Authorization: {{authHeader}}

###
# Create Course Offering
POST {{baseUrl}}/api/v1/course-offering/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "maxStudents": 30,
  "currentStudents": 0,
  "openTime": "2023-08-01T09:00:00",
  "closeTime": "2023-08-20T17:00:00",
  "courseId": {{courseId}},
  "semesterId": {{semesterId}},
  "teacherId": {{teacherId}},
  "classroomId": {{classroomId}}
}

###
# Create Another Course Offering
POST {{baseUrl}}/api/v1/course-offering/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "maxStudents": 25,
  "currentStudents": 0,
  "openTime": "2023-08-01T09:00:00",
  "closeTime": "2023-08-20T17:00:00",
  "courseId": 2,
  "semesterId": {{semesterId}},
  "teacherId": {{teacherId}},
  "classroomId": {{classroomId}}
}

###
# Create Large Lecture Course Offering
POST {{baseUrl}}/api/v1/course-offering/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "maxStudents": 100,
  "currentStudents": 0,
  "openTime": "2023-08-01T09:00:00",
  "closeTime": "2023-08-20T17:00:00",
  "courseId": 3,
  "semesterId": {{semesterId}},
  "teacherId": {{teacherId}},
  "classroomId": {{classroomId}}
}

###
# Update Course Offering
POST {{baseUrl}}/api/v1/course-offering/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "id": {{courseOfferingId}},
  "maxStudents": 35,
  "currentStudents": 0,
  "openTime": "2023-08-01T09:00:00",
  "closeTime": "2023-08-25T17:00:00",
  "courseId": {{courseId}},
  "semesterId": {{semesterId}},
  "teacherId": {{teacherId}},
  "classroomId": {{classroomId}}
}

###
# Delete Course Offering
DELETE {{baseUrl}}/api/v1/course-offering/delete/{{courseOfferingId}}
Authorization: {{authHeader}}

###
# Validate Course Offering (Service-to-Service)
GET {{baseUrl}}/api/v1/course-offering/{{courseOfferingId}}/validate
Authorization: {{authHeader}}

# ========================================
# COURSE REGISTRATION ENDPOINTS
# ========================================

###
# Get All Course Registrations
GET {{baseUrl}}/api/v1/course-registration/all
Authorization: {{authHeader}}

###
# Get Course Registration by ID
GET {{baseUrl}}/api/v1/course-registration/details/{{courseRegistrationId}}
Authorization: {{authHeader}}

###
# Create Course Registration
POST {{baseUrl}}/api/v1/course-registration/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "registrationDate": "2023-08-15T10:30:00",
  "courseRegistrationStatus": "REGISTERED",
  "studentId": {{studentId}},
  "courseOfferingId": {{courseOfferingId}}
}

###
# Create Another Course Registration
POST {{baseUrl}}/api/v1/course-registration/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "registrationDate": "2023-08-16T14:20:00",
  "courseRegistrationStatus": "REGISTERED",
  "studentId": 2,
  "courseOfferingId": {{courseOfferingId}}
}

###
# Create Registration for Different Course
POST {{baseUrl}}/api/v1/course-registration/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "registrationDate": "2023-08-17T09:15:00",
  "courseRegistrationStatus": "REGISTERED",
  "studentId": {{studentId}},
  "courseOfferingId": 2
}

###
# Update Course Registration Status
POST {{baseUrl}}/api/v1/course-registration/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "id": {{courseRegistrationId}},
  "registrationDate": "2023-08-15T10:30:00",
  "courseRegistrationStatus": "COMPLETED",
  "studentId": {{studentId}},
  "courseOfferingId": {{courseOfferingId}}
}

###
# Drop Course Registration
POST {{baseUrl}}/api/v1/course-registration/save
Content-Type: {{contentType}}
Authorization: {{authHeader}}

{
  "id": {{courseRegistrationId}},
  "registrationDate": "2023-08-15T10:30:00",
  "courseRegistrationStatus": "DROPPED",
  "studentId": {{studentId}},
  "courseOfferingId": {{courseOfferingId}}
}

###
# Delete Course Registration
DELETE {{baseUrl}}/api/v1/course-registration/delete/{{courseRegistrationId}}
Authorization: {{authHeader}}

###
# Validate Course Registration (Service-to-Service)
GET {{baseUrl}}/api/v1/course-registration/{{courseRegistrationId}}/validate
Authorization: {{authHeader}} 